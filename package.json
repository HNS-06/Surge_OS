{
  "name": "surge-os",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Tactical Productivity Command Center - AI-powered academic scheduling and cognitive block diagnosis",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
